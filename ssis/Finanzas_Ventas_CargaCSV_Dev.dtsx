    <DTS:Executable
      DTS:refId="Package\RegistrarEjecucion"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Bloque que inserta un registro en la tabla de log cada vez que corre el paquete."
      DTS:DTSID="{A440EA7F-A097-482C-AD11-BBAAB4AC6761}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="RegistrarEjecucion"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:PropertyExpression
        DTS:Name="SqlStatementSource">"INSERT INTO LogEjecucion (
    FechaEjecucion, FilasValidas, FilasInvalidas,
    FilasErrorConversion, NombrePaquete, NombreArchivo,
    MensajeError, Estado, DuracionSegundos,
    FilasPagosValidas, FilasPagosInvalidas, FilasErrorConvPagos
) VALUES (
    GETDATE(),"
+ (DT_WSTR,10)@[User::FilasValidas] + ","
+ (DT_WSTR,10)@[User::FilasInvalidas] + ","
+ (DT_WSTR,10)@[User::FilasErrorConversion] + ",'"
+ @[System::PackageName] + "','"
+ @[User::NombreArchivo] + "','"
+ @[User::MensajeError] + "','"
+ @[User::EstadoEjecucion] + "',"
+ (DT_WSTR,10)DATEDIFF("ss",@[User::FechaInicio],GETDATE()) + ","
+ (DT_WSTR,10)@[User::FilasPagosValidas] + ","
+ (DT_WSTR,10)@[User::FilasPagosInvalidas] + ","
+ (DT_WSTR,10)@[User::FilasErrorConversionPagos] + ")"</DTS:PropertyExpression>
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{DF02D845-24CE-47EA-887E-499D69EA0A6A}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="INSERT INTO LogEjecucion (&#xA;    FechaEjecucion, FilasValidas, FilasInvalidas,&#xA;    FilasErrorConversion, NombrePaquete, NombreArchivo,&#xA;    MensajeError, Estado, DuracionSegundos,&#xA;    FilasPagosValidas, FilasPagosInvalidas, FilasErrorConvPagos&#xA;) VALUES (&#xA;    GETDATE(),0,0,0,'Finanzas_Ventas_CargaCSV_Dev','C:\Cursos\SSIS\FICOHSA_Finanzas_Ventas_ETL_Dev\data\DEV\ventas.csv','','EXITOSO',772,0,0,0)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::FilasValidas"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="3"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
