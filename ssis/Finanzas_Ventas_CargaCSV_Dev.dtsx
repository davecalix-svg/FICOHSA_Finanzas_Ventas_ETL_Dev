                      containsID="true"
                      dataType="System.String"
                      description="Especifica la expresión. Esta versión de expresión usa identificadores de linaje en lugar de nombres de columna."
                      name="Expression">![ISNULL](#{Package\CargaPagosCSV\CNV_Pagos.Outputs[Salida de conversión de datos].Columns[ClienteId_Int]}) &amp;&amp; #{Package\CargaPagosCSV\CNV_Pagos.Outputs[Salida de conversión de datos].Columns[Monto_Num]} &gt; 0 &amp;&amp; (#{Package\CargaPagosCSV\SRC_FF_Pagos.Outputs[Salida de origen de archivo plano].Columns[Estado]} == "Completado" || #{Package\CargaPagosCSV\SRC_FF_Pagos.Outputs[Salida de origen de archivo plano].Columns[Estado]} == "Pendiente" || #{Package\CargaPagosCSV\SRC_FF_Pagos.Outputs[Salida de origen de archivo plano].Columns[Estado]} == "Rechazado" || #{Package\CargaPagosCSV\SRC_FF_Pagos.Outputs[Salida de origen de archivo plano].Columns[Estado]} == "Anulado")</property>
